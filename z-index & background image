CSS:
div{
    height:100px;
    width:100px;
    background-color: aqua;
    border: 2px solid black;
    display:inline-block;
}

#box1{
    position:static;
}

#box2{
    position:relative;
    top:20px;
    left:10px;
    z-index:1;
    background-image:url("nails.jpg");
    background-size:cover;
}

#box3{
    position:absolute;
    top:500px;
    left:20px;
    background-image:url("nails.jpg");
    background-size:contain;
}

#box4{
    position:fixed;
    top:50px;
}
