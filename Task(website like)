CSS:
*{
    padding:0;
    margin:0;
}

#amazon{
    height:60px;
    background-color:black;
}
#a1{
    color:#f08804;
    font-size:25px;
}
a{
    color:white;
    margin-right:100px;
}
button{
    background-color:#f08804;
}

.contentBox{
    height: 100px;
    width: 100px;
    border: 2px solid black;
    display: inline-block;
    margin:10px;
    display:inline-block;
}

#content{
    height:550px;
}

footer{
    background-color:black;
    color:white;
    text-align:center;
}
