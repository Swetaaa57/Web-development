CSS:
div{
    height:500px;
    width:200px;
    background-color:grey;
    border-width:5px;
    border-style: solid;
    border-color:black;
    border-radius:10px; /*for circle- 50% */
}

#red{
    height:130px;
    width:130px;
    background-color:red;
    border-radius:50%;
    margin-left:35px;
}
#yellow{
    height:130px;
    width:130px;
    background-color:yellow;
    border-radius:50%;
    margin-left:35px;
}
#green{
    height:130px;
    width:130px;
    background-color:green;
    border-radius:50%;
    margin-left:35px;
}
