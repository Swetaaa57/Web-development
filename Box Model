CSS:
div{
    height:100px; /* hi */
    width:200px;
    background-color: pink;
    border-width:5px;
    border-style: solid;
    border-color:brown;
    text-align:center;
    border-radius:10px; /*for circle- 50% */
}

h4{
    height:70px;
    width:150px;
    background-color:blanchedalmond;
    border: 4px solid black;
    padding-left:25px;
    padding-right:25px;
    padding-top:25px;
    padding-bottom:25px;
}

p{
    height:70px;
    width:150px;
    border: 4px solid chocolate;
    background-color:lavender;
    padding:20px;
}

h5{
    height:70px;
    width:150px;
    border: 4px solid chocolate;
    background-color:lavender;
    padding:4px 5px 6px 7px;
    margin-top:50px;
}
